{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.0.0, 5.0.0)"
  },
  "extensions": {
    "eventHubs": {
      "maxEventBatchSize" : 64,
      "batchCheckpointFrequency" : 5,
      "prefetchCount" : 256,
      "initialOffsetOptions" : {
          "type" : "fromStart"
      }
    },
    "http": {
      "routePrefix": ""
    },
    "queues": {
      "maxPollingInterval": "00:00:02",
      "visibilityTimeout": "00:00:10",
      "batchSize": 32,
      "maxDequeueCount": 5,
      "messageEncoding": "none"
    }
  },
  "logging": {
    "fileLoggingMode": "debugOnly",
    "logLevel": {
      "Function.BizEventEnrichmentProcessor": "Information",
      "Function.EventHubBizEventProcessor": "Information",
      "Function.BizEventToView": "Information",
      "Function.BizEventToViewQueueTrigger": "Information"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "maxTelemetryItemsPerSecond": 5,
        "includedTypes": "PageView;Trace;Dependency;Request",
        "excludedTypes": "Exception;Event;CustomEvent"
      }
    }
  }
}
